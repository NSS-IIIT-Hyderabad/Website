# Production Environment Configuration Template
# Copy this to .env.production and fill in with your actual values

# API Configuration
API_ENV=production
API_CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/nss_db
MONGODB_USER=nss_admin
MONGODB_PASSWORD=YOUR_STRONG_MONGODB_PASSWORD_HERE

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
GRAPHQL_URL=https://yourdomain.com/graphql
UPLOAD_DIR=/var/www/nss-uploads
UPLOADS_HOST_DIR=/var/www/nss-uploads
MAX_FILE_SIZE=10485760

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://yourdomain.com/graphql
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_UPLOADS_BASE_URL=https://yourdomain.com

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD_HERE

# Security
SECRET_KEY=YOUR_DJANGO_SECRET_KEY_HERE

# Email Configuration (optional, for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Logging
LOG_LEVEL=info

# Google Maps API (if used)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# Database Backup (for scripts)
BACKUP_RETENTION_DAYS=7
BACKUP_LOCATION=/backups/mongodb

# Monitoring
GRAFANA_ADMIN_PASSWORD=YOUR_STRONG_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=30d

# OAuth (if using GitHub Actions for CI/CD)
GITHUB_TOKEN=your-github-personal-access-token
